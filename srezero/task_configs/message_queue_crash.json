    "inspect_metrics:message_queue": "Message queue metrics show publish errors and growing queue depth."
  },
  "correct_fix": {
    "action_type": "restart_service",
    "service": "message_queue",
    "fix_keywords": ["restart", "message queue"]
  },
  "service_patches": {
