      "metrics": {
        "queue_depth": 1840,
        "oldest_message_age_ms": 92000,
        "publish_error_rate": 1.0,
        "consumer_lag_ms": 87000,
        "dead_letter_rate": 0.02,
        "cpu_steal_pct": 3
      }
    },
    "web_server": {
      "logs": [
        "WARN async job publish timeout for request_id=8101",
        "INFO request_id=8102 path=/ status=200 latency_ms=70"
      ],
      "metrics": {
        "error_rate": 0.02,
        "p95_latency_ms": 190
      }
    }
  },
  "expected_action_pattern": [
    "check_status(message_queue)",
    "inspect_logs(message_queue)",
    "inspect_metrics(message_queue)",
    "restart_service(message_queue)",
    "resolve_incident(message queue service crashed, restart message queue service)"
