{
  "task_id": "message_queue_crash",
  "difficulty": "easy",
  "alert": "Background jobs are delayed and the message queue is not acknowledging publishes.",
  "root_cause": "message queue service crashed",
  "root_cause_keywords": ["message queue", "crashed", "publishes"],
  "relevant_evidence": [
    "check_status:message_queue",
    "inspect_logs:message_queue",
    "inspect_metrics:message_queue"
  ],
  "evidence_descriptions": {
